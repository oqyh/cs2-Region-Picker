<Window x:Class="CS2RegionPicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CS2RegionPicker"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="CS2 Region Picker" Width="900" Height="820" MinWidth="740" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        Icon="app.ico"
        UseLayoutRounding="True" FontFamily="Segoe UI">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="7" CornerRadius="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Padding" Value="22,11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHover}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="bd" Property="Opacity" Value="0.45"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSec" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BtnSecBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="{DynamicResource BtnSecHover}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="bd" Property="Opacity" Value="0.45"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="{DynamicResource BtnSecBg}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SocialButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="7,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="13" Background="{DynamicResource WinBg}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BtnSecBg}"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="t" CornerRadius="4" Margin="2,2" Background="{DynamicResource ScrollThumb}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="t" Property="Background" Value="{DynamicResource ScrollThumbHover}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="t" Property="Background" Value="{DynamicResource ScrollThumbHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollNoButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollNoButton}" Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb><Thumb Style="{StaticResource ScrollThumbStyle}" MinHeight="24"/></Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollNoButton}" Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Height" Value="10"/>
                                <Setter TargetName="PART_Track" Property="MinHeight" Value="0"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboToggle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" CornerRadius="7"
                                Background="{DynamicResource InputBg}"
                                BorderBrush="{DynamicResource InputBorder}" BorderThickness="1">
                            <Grid>
                                <ContentPresenter Margin="10,0,26,0" VerticalAlignment="Center"/>
                                <Path x:Name="arrow" Data="M 0 0 L 4 4 L 8 0 Z" Fill="{DynamicResource TextSecondary}"
                                      HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="PART_Toggle" Style="{StaticResource ComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" PopupAnimation="Fade" Focusable="False">
                                <Border Background="{DynamicResource DropdownBg}" BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1" CornerRadius="7" Margin="0,4,0,0" Padding="4"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True"/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="Transparent" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource DropdownHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BtnSecBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WinBg}" CornerRadius="12" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
        <Grid Margin="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" x:Name="TitleBar" Height="48" Background="{DynamicResource DragBarBg}" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Image Source="app.png" Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,11,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="CS2 Region Picker" FontSize="15" FontWeight="Bold"
                             Foreground="{DynamicResource TextPrimary}"/>
                        <Run Text=" [1.0.0]" FontSize="10"
                             Foreground="{DynamicResource TextSecondary}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button x:Name="SettingsBtn" Style="{StaticResource BtnSec}" Margin="0,0,8,0"
                            Content="⚙  Settings" Click="Settings_Click"/>
                    <Button x:Name="AboutBtn" Style="{StaticResource BtnSec}"
                            Content="About" Click="About_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button x:Name="MinBtn" Style="{StaticResource ChromeBtn}" Content="—" Click="Min_Click"/>
                    <Button x:Name="CloseBtn" Style="{StaticResource ChromeBtn}" Content="✕" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="16,10,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10" x:Name="FinderRow">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource InputBorder}"
                            BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <TextBlock Text="Search region…" Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                       Margin="12,0,0,0" VerticalAlignment="Center" x:Name="SearchPlaceholder" IsHitTestVisible="False"/>
                            <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}"
                                     Padding="12,10" FontSize="13" TextChanged="SearchBox_TextChanged"
                                     GotKeyboardFocus="SearchBox_Focus"
                                     LostKeyboardFocus="SearchBox_LostFocus"
                                     PreviewMouseLeftButtonDown="SearchBox_Click"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="1" x:Name="AllBtn" Style="{StaticResource BtnSec}" Margin="8,0,0,0"
                            Content="Mark All" Click="SelectAll_Click"/>
                    <Button Grid.Column="2" x:Name="NoneBtn" Style="{StaticResource BtnSec}" Margin="8,0,0,0"
                            Content="UnMark All" Click="SelectNone_Click"/>
                </Grid>

                <Border Grid.Row="1" Background="{DynamicResource MapSea}" BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                    <Grid>
                        <local:WorldMap x:Name="Map"/>

                        <Border x:Name="AppliedPanel" VerticalAlignment="Top" HorizontalAlignment="Right"
                                Margin="0,12,12,0" Width="238" CornerRadius="10"
                                Background="{DynamicResource DropdownBg}" BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="1" Padding="12,10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.32" Color="Black"/>
                            </Border.Effect>
                            <StackPanel>
                                <DockPanel Margin="0,0,0,2">
                                    <TextBlock x:Name="ActiveTitle" Text="Current Allowed Regions" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                    <Border DockPanel.Dock="Right" HorizontalAlignment="Right" CornerRadius="9"
                                            Background="{DynamicResource BtnSecBg}" Padding="7,1" VerticalAlignment="Center">
                                        <TextBlock x:Name="AppliedCount" Text="0" FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource Accent}"/>
                                    </Border>
                                </DockPanel>

                                <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,8,0,8"/>

                                <TextBlock x:Name="AppliedEmpty" Text="Nothing Applied Yet — Hit Apply" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>

                                <ScrollViewer x:Name="AppliedScroll" MaxHeight="180" VerticalScrollBarVisibility="Auto"
                                              Visibility="Collapsed">
                                    <ItemsControl x:Name="AppliedList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,2">
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding PingText}" FontSize="10.5"
                                                               FontWeight="SemiBold" Foreground="{Binding PingBrush}"
                                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                                               MinWidth="46" TextAlignment="Right"/>
                                                    <Ellipse DockPanel.Dock="Left" Width="7" Height="7" Margin="0,0,7,0"
                                                             VerticalAlignment="Center" Fill="{Binding StateBrush}"/>
                                                    <TextBlock Text="{Binding Desc}" FontSize="11.5"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border x:Name="ResultsPanel" Visibility="Collapsed" VerticalAlignment="Top" HorizontalAlignment="Left"
                                Background="{DynamicResource DropdownBg}" BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="1" CornerRadius="8" Margin="10" MaxHeight="300" Width="380">
                            <ListBox x:Name="ResultsList" Background="Transparent" BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     Focusable="False"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="12,8"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="bd" Background="Transparent" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource DropdownHover}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Cursor="Hand" Background="Transparent" MouseLeftButtonDown="Result_Click" Tag="{Binding}" LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding PingText}" FontSize="12"
                                                       FontWeight="SemiBold" Foreground="{Binding PingBrush}" VerticalAlignment="Center"
                                                       Margin="12,0,0,0" MinWidth="52" TextAlignment="Right"/>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding StateText}" FontSize="11"
                                                       FontWeight="SemiBold" Foreground="{Binding StateBrush}" VerticalAlignment="Center"
                                                       Margin="10,0,0,0" MinWidth="72" TextAlignment="Right"/>
                                            <Ellipse DockPanel.Dock="Left" Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,9,0" Fill="{Binding StateBrush}"/>
                                            <Border DockPanel.Dock="Left" CornerRadius="2" Margin="0,0,8,0"
                                                    VerticalAlignment="Center" ClipToBounds="True"
                                                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="0.6">
                                                <Image Source="{Binding FlagPath}" Width="20" Height="15"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
                                            <TextBlock Text="{Binding Desc}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,12,0,10" x:Name="ActionRow">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" x:Name="LockBadge" Visibility="Collapsed" HorizontalAlignment="Left"
                            Background="{DynamicResource BtnSecBg}" CornerRadius="6" Padding="10,6" VerticalAlignment="Center">
                        <TextBlock x:Name="LockBadgeText" Text="🔒  Working… please wait" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Warning}"/>
                    </Border>

                    <Button Grid.Column="2" x:Name="ApplyBtn" Style="{StaticResource BtnPrimary}"
                            Content="▶  Apply" Click="Apply_Click"/>
                </Grid>

                <Border Grid.Row="3" Background="{DynamicResource LogBg}" BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1" CornerRadius="10">
                    <RichTextBox x:Name="LogBox" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                 Background="Transparent" BorderThickness="0" Padding="12,8"
                                 Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas" FontSize="12"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <RichTextBox.Resources>
                            <Style TargetType="{x:Type Paragraph}">
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </RichTextBox.Resources>
                    </RichTextBox>
                </Border>
            </Grid>

            <Border x:Name="SettingsOverlay" Grid.RowSpan="2" Visibility="Collapsed"
                    Background="#99000000" CornerRadius="12">
                <Border Width="380" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,18">
                            <TextBlock x:Name="SettingsTitle" Text="Settings" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource ChromeBtn}" Content="✕"
                                    HorizontalAlignment="Right" Click="SettingsClose_Click"/>
                        </DockPanel>

                        <DockPanel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="ThemeLabel" Text="Appearance" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="ThemeSubLabel" Text="Dark or light theme" FontSize="11.5" Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                            <Border DockPanel.Dock="Right" x:Name="ThemeToggle" Width="60" Height="30" CornerRadius="15"
                                    Background="{DynamicResource ToggleTrackBg}" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    MouseLeftButtonDown="ThemeToggle_Click">
                                <Border x:Name="ThemeKnob" Width="24" Height="24" CornerRadius="12" HorizontalAlignment="Left"
                                        Background="{DynamicResource ToggleKnobBg}" Margin="3,0,0,0">
                                    <Border.RenderTransform><TranslateTransform x:Name="ThemeKnobT" X="0"/></Border.RenderTransform>
                                    <TextBlock x:Name="ThemeKnobIcon" Text="🌙" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </DockPanel>

                        <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,16,0,16"/>

                        <DockPanel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="LangLabel" Text="Language" FontSize="13.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="LangSubLabel" Text="Interface language" FontSize="11.5"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                            <ComboBox x:Name="LangCombo" DockPanel.Dock="Right" Width="118"
                                      Style="{StaticResource ThemedCombo}"
                                      ItemContainerStyle="{StaticResource ThemedComboItem}"
                                      HorizontalAlignment="Right" VerticalAlignment="Center"
                                      SelectionChanged="Lang_Changed">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Native}" FontSize="12.5"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Border>
            <Border x:Name="AboutOverlay" Grid.RowSpan="2" Visibility="Collapsed"
                    Background="#99000000" CornerRadius="12" MouseLeftButtonDown="AboutOverlay_Click">
                <Border Width="400" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{DynamicResource CardBg}" CornerRadius="16"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" MouseLeftButtonDown="AboutCard_Click">
                    <Border.Clip><RectangleGeometry Rect="0,0,400,500" RadiusX="16" RadiusY="16"/></Border.Clip>
                    <StackPanel>

                        <Grid Height="150">
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#2B2F36" Offset="0"/>
                                        <GradientStop Color="#16181C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Image Source="app.png" Width="72" Height="72" HorizontalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock HorizontalAlignment="Center" FontSize="20" Margin="0,8,0,0">
                                        <Run Text="CS2 Region " FontWeight="Light" Foreground="White"/><Run Text="Picker" FontWeight="SemiBold" Foreground="White"/>
                                    </TextBlock>
                                    <TextBlock Text="Version 1.0.0" HorizontalAlignment="Center" FontSize="11" Foreground="#9AA6B2" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Button Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,12,0"
                                    Cursor="Hand" Click="AboutClose_Click" ToolTip="Close">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" CornerRadius="8" Background="#26FFFFFF">
                                            <TextBlock Text="✕" FontSize="12" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#44FFFFFF"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <StackPanel Margin="0,22,0,0">
                            <TextBlock x:Name="AboutTitleText" Text="Created By" TextAlignment="Center" FontSize="13" Foreground="{DynamicResource TextSecondary}"/>
